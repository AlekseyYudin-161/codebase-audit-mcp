│       ├── sample_with_smells.py   # файл с секретами, eval(), длинными функциями
│       └── sample_clean.py         # чистый файл — проверка false positives
│
├── demo_project/                   # тестовый мини-проект для DEMO.md
│   ├── README.md
│   ├── app/
